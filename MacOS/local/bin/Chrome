#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import webbrowser
import time
from urllib.parse import quote, urlparse, urlunparse

# 原始网址列表（含中文）
urls = [
    "http://192.168.10.2:50000/Lexar/色色/Desktop/A-绝美的臀部2",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/好腿知我意-长在我心里",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/完美的身材",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/性感的乳房",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/三角地带",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/脸蛋不错",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/A-超绝",
    "http://192.168.10.2:50000/Lexar/色色/Desktop/A-一切都超绝"
    # "http://192.168.10.2:50000/Desktop/",
    # "http://192.168.10.2:50000/Desktop/",
    # "http://192.168.10.2:50000/Desktop/",
    # "http://192.168.10.2:50000/Desktop/",
    # "http://192.168.10.2:50000/Desktop/"
]

# macOS 下 Chrome 路径（Windows/Linux 请更改此路径）
chrome_path = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
webbrowser.register('chrome', None, webbrowser.BackgroundBrowser(chrome_path))

def encode_url(url):
    """将网址中中文路径、查询参数编码"""
    parsed = urlparse(url)
    encoded_path = quote(parsed.path)
    encoded_query = quote(parsed.query, safe='=&')
    return urlunparse((parsed.scheme, parsed.netloc, encoded_path, '', encoded_query, ''))

for url in urls:
    full_url = encode_url(url)
    webbrowser.get('chrome').open_new_tab(full_url)
    time.sleep(0.5)
