#!/bin/bash

if [ $1 == '-r' -o $1 == 'run' ]; then
 	$HOME/DevTools/nacos/bin/startup.sh -m standalone
	tail -f $HOME/DevTools/nacos/logs/startup.log
elif [ $1 == '-s' -o $1 == 'stop' ]; then
	$HOME/DevTools/nacos/bin/shutdown.sh
elif [ $1 == '-l' -o $1 == 'logs' ]; then
	tail -f $HOME/DevTools/nacos/logs/startup.log
else
	echo 'use -r - run  | Nacos Run'
	echo 'use -s - stop | Nacos Stop'
	echo 'use -l - logs | Nacos Show Logs'
fi

